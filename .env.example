# Copy this file to two places:
#   server/.env  — backend (DATABASE_URL, CLERK_*, OPENROUTER_API_KEY)
#   client/.env  — frontend (VITE_*)
#
# Both files are gitignored. Never commit real keys.

# ─── Server ───────────────────────────────────────────────────────────────────

# AI gateway — get a key from https://openrouter.ai
OPENROUTER_API_KEY=

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/aiph

# Clerk — both required for auth to be active
# https://dashboard.clerk.com/last-active?path=api-keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Express server
PORT=4000
NODE_ENV=development

# ─── Client (Vite) ────────────────────────────────────────────────────────────

# Same publishable key as CLERK_PUBLISHABLE_KEY above, exposed to the browser
VITE_CLERK_PUBLISHABLE_KEY=

# Backend base URL — leave empty in dev to use the Vite proxy
VITE_API_URL=http://localhost:4000
