// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core user identity
model User {
  id              String   @id @default(cuid())
  clerkId         String   @unique
  email           String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         UserProfile?
  attempts        Attempt[]
  patterns        PatternMastery[]
  topics          TopicProgress[]
  weakAreas       WeakArea[]
  chatMessages    ChatMessage[]
  chatSessions             ChatSession[]
  systemDesignAttempts     SystemDesignAttempt[]
  systemDesignProgress     SystemDesignProgress[]
}

// User preferences and settings
model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  experienceLevel String?  // beginner | intermediate | advanced
  targetRole      String?  // frontend | backend | fullstack
  timelineDays    Int?     // days until interview
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Topic metadata
model Topic {
  id          String   @id @default(cuid())
  name        String   @unique // Arrays, Trees, Graphs, etc.
  description String?
  createdAt   DateTime @default(now())

  progresses  TopicProgress[]
  problems    Problem[]
  weakAreas   WeakArea[]
}

// Topic-level progress per user
model TopicProgress {
  id              String   @id @default(cuid())
  userId          String
  topicId         String
  masteryScore    Int      @default(0)  // 0-100
  attemptCount    Int      @default(0)
  successCount    Int      @default(0)
  averageSolveTime Int?    // minutes
  lastReviewed    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
}

// DSA Pattern metadata
model Pattern {
  id          String   @id @default(cuid())
  name        String   @unique // Sliding Window, Two Pointers, etc.
  description String?
  createdAt   DateTime @default(now())

  masteries  PatternMastery[]
  problems   Problem[]
  weakAreas  WeakArea[]
}

// Pattern-level mastery per user
model PatternMastery {
  id              String   @id @default(cuid())
  userId          String
  patternId       String
  masteryScore    Int      @default(0)  // 0-100
  confidenceScore Int      @default(0)  // 0-100
  attemptCount    Int      @default(0)
  solvedCount     Int      @default(0)
  averageSolveTime Int?    // minutes
  lastReviewed    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern Pattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@unique([userId, patternId])
  @@index([userId])
  @@index([patternId])
}

// Coding problem definition
model Problem {
  id          String   @id @default(cuid())
  title       String
  difficulty  String   // easy | medium | hard
  topicId     String
  patternId   String
  source      String?  // leetcode url
  description String?  @db.Text
  createdAt   DateTime @default(now())

  topic    Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  pattern  Pattern  @relation(fields: [patternId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@index([topicId])
  @@index([patternId])
}

// User's attempt at a problem
model Attempt {
  id              String   @id @default(cuid())
  userId          String
  problemId       String
  status          String   // solved | attempted | failed
  solveTime       Int      // minutes
  hintsUsed       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  submission AttemptSubmission?

  @@index([userId])
  @@index([problemId])
  @@index([createdAt])
}

// Approach evaluation and AI feedback
model AttemptSubmission {
  id                 String   @id @default(cuid())
  attemptId          String   @unique
  approachText       String   @db.Text
  language           String?  // e.g. python, javascript, java, cpp
  codeSubmission     String?  @db.Text
  aiScore            Int?     // 0-100
  timeComplexity     String?  // O(n)
  spaceComplexity    String?  // O(n)
  feedback           String?  @db.Text
  patternIdentified  String?
  suggestedOptimization String?
  evaluatedAt        DateTime @default(now())
  createdAt          DateTime @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

// Detected weak areas
model WeakArea {
  id          String   @id @default(cuid())
  userId               String
  topicId              String?
  patternId            String?
  systemDesignTopicId  String?
  reason               String   // slow | confused | failing
  severity    Int      @default(1)  // 1-3
  detectedAt  DateTime @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic   Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  pattern Pattern? @relation(fields: [patternId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([topicId])
  @@index([patternId])
  @@index([systemDesignTopicId])
  @@index([detectedAt])
}

// Chat session (groups messages into conversations)
model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([userId, updatedAt])
}

// Chat conversation history
model ChatMessage {
  id        String       @id @default(cuid())
  userId    String
  sessionId String?      // nullable — existing rows have no session
  role      String       // user | assistant
  content   String       @db.Text
  createdAt DateTime     @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@index([createdAt])
}

// ─── System Design ────────────────────────────────────────────────────────────

model SystemDesignTopic {
  id              String   @id @default(cuid())
  name            String   @unique
  category        String
  description     String   @db.Text
  difficulty      String   // beginner | intermediate | advanced
  prerequisiteIds String[] @default([])
  createdAt       DateTime @default(now())

  questions SystemDesignQuestionTopic[]
  progress  SystemDesignProgress[]
}

model SystemDesignQuestion {
  id               String   @id @default(cuid())
  prompt           String   @db.Text
  difficulty       String   // easy | medium | hard
  expectedConcepts String[]
  resources        Json     @default("[]")  // [{title, url, type}]
  createdAt        DateTime @default(now())

  topics   SystemDesignQuestionTopic[]
  attempts SystemDesignAttempt[]
}

// Explicit join table — needed for "questions by topic" filter queries
model SystemDesignQuestionTopic {
  questionId String
  topicId    String

  question SystemDesignQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic    SystemDesignTopic    @relation(fields: [topicId],    references: [id], onDelete: Cascade)

  @@id([questionId, topicId])
  @@index([topicId])
}

model SystemDesignAttempt {
  id           String   @id @default(cuid())
  userId       String
  questionId   String
  responseText String   @db.Text
  createdAt    DateTime @default(now())

  user     User                       @relation(fields: [userId],     references: [id], onDelete: Cascade)
  question SystemDesignQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  result   SystemDesignAttemptResult?

  @@index([userId])
  @@index([questionId])
  @@index([userId, createdAt])
}

model SystemDesignAttemptResult {
  id                        String   @id @default(cuid())
  attemptId                 String   @unique
  score                     Int      // 0-100
  requirementsClarification Int      // 0-25
  componentCoverage         Int      // 0-25
  scalabilityReasoning      Int      // 0-25
  tradeoffAwareness         Int      // 0-25
  feedback                  String   @db.Text
  missingConcepts           String[]
  suggestedDeepDive         String?
  createdAt                 DateTime @default(now())

  attempt SystemDesignAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model SystemDesignProgress {
  id           String   @id @default(cuid())
  userId       String
  topicId      String
  masteryScore Int      @default(0)
  attemptCount Int      @default(0)
  lastReviewed DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User              @relation(fields: [userId],  references: [id], onDelete: Cascade)
  topic SystemDesignTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
}
